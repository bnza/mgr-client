{
  "name": "medgr-client",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "compare:query-params": "npx tsx bin/compare-query-params.ts",
    "dev": "nuxt dev",
    "eslint:check": "eslint --ext .js,.ts,.tsx,.vue,.mjs --fix-dry-run",
    "generate": "nuxt generate",
    "generate:openapi": "npx tsx bin/generate-openapi-types.ts && prettier --write types/openapi.d.ts",
    "generate:api-resources": "npx tsx bin/generate-api-resources-types.ts && prettier --write app/utils/consts/resources.ts",
    "generate:all": "pnpm generate:openapi && pnpm generate:api-resources",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,vue,css,scss,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,vue,css,scss,json,md}\" --ignore-path .prettierignore",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test:e2e": "playwright test",
    "test:e2e:codegen": "playwright codegen --viewport-size=1600,1000 http://localhost",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "typecheck:tests": "vue-tsc --noEmit -p tests/tsconfig.json --composite false",
    "typecheck:all": "pnpm typecheck && pnpm typecheck:tests"
  },
  "dependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "@pinia/colada": "^1.1.0",
    "@pinia/colada-nuxt": "^0.3.2",
    "@pinia/colada-plugin-retry": "^0.2.3",
    "@pinia/nuxt": "^0.11.3",
    "@regle/core": "^1.21.5",
    "@regle/nuxt": "^1.21.5",
    "@regle/rules": "^1.21.5",
    "@sidebase/nuxt-auth": "^1.2.0",
    "@types/jsonld": "^1.5.15",
    "deep-object-diff": "^1.1.9",
    "dotenv": "^17.4.0",
    "js-sha256": "^0.11.1",
    "nuxt": "^4.4.2",
    "ol": "^10.8.0",
    "ol-contextmenu": "^6.0.0",
    "ol-ext": "^4.0.38",
    "pinia": "^3.0.4",
    "qs": "^6.15.0",
    "vue": "latest",
    "vue-router": "latest",
    "vue3-openlayers": "^12.2.2",
    "vuetify": "^4.0.5",
    "vuetify-nuxt-module": "^1.0.0-beta.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@pinia/colada-devtools": "^0.4.5",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "openapi-types": "^12.1.3",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "vue": "latest"
  }
}
